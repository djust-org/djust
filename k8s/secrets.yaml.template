# Template for secrets - DO NOT commit actual secrets to git!
# Copy this file to secrets.yaml and fill in the values
apiVersion: v1
kind: Secret
metadata:
  name: djust-secret
  namespace: djust
type: Opaque
stringData:
  # Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
  secret-key: "REPLACE_WITH_DJANGO_SECRET_KEY"
