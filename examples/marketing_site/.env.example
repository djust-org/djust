# Django Core Settings
# ===================

# SECURITY WARNING: Generate a secure secret key for production!
# You can generate one with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your-secret-key-here

# Debug mode - ALWAYS set to false in production
DEBUG=True

# Allowed hosts - comma-separated list of domains
# Example: ALLOWED_HOSTS=example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0


# djust Configuration
# ===================

# State backend: 'memory' for development, 'redis' for production
DJUST_STATE_BACKEND=memory

# Redis URL for djust state backend (only used if DJUST_STATE_BACKEND=redis)
# Format: redis://[username:password@]host:port/database
REDIS_URL=redis://127.0.0.1:6379/0

# Session TTL in seconds (default: 3600 = 1 hour)
DJUST_SESSION_TTL=3600


# Cache Configuration
# ===================

# Cache backend: 'locmem' for development, 'redis' for production
CACHE_BACKEND=locmem

# Redis URL for Django cache (only used if CACHE_BACKEND=redis)
# Use different database number than REDIS_URL to avoid conflicts
REDIS_CACHE_URL=redis://127.0.0.1:6379/1


# GitHub Integration
# ==================

# GitHub repository for star count display (format: owner/repo)
# Leave empty to disable GitHub API calls
GITHUB_REPO=


# Production Deployment Notes
# ===========================
#
# 1. Generate secure SECRET_KEY:
#    python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
#
# 2. Set DEBUG=False
#
# 3. Configure ALLOWED_HOSTS with your domain(s)
#
# 4. For horizontal scaling, use Redis:
#    - Set DJUST_STATE_BACKEND=redis
#    - Set CACHE_BACKEND=redis
#    - Configure REDIS_URL and REDIS_CACHE_URL
#
# 5. Install Redis dependencies:
#    pip install redis django-redis
#
# 6. Run collectstatic for static files:
#    python manage.py collectstatic --noinput
#
# 7. Use production ASGI server (Daphne, Uvicorn, or Hypercorn):
#    daphne -b 0.0.0.0 -p 8000 marketing_project.asgi:application
